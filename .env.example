# Database (required for app and scripts)
# Local Supabase: postgresql://postgres:postgres@127.0.0.1:54322/postgres (after bun run supabase:start)
# Remote: Supabase Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Gemini AI Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model name for recipe details (e.g. gemini-2.5-flash-lite, gemini-2.0-flash)
GEMINI_MODEL=gemini-2.5-flash-lite

# Main page password protection
# ACCESS_PASSWORD_HASH format: scrypt$<salt_hex>$<hash_hex>
# Generate with Node:
# node -e 'const { randomBytes, scryptSync } = require("node:crypto"); const p="your_password"; const salt=randomBytes(16); const hash=scryptSync(p, salt, 64); console.log("scrypt$" + salt.toString("hex") + "$" + hash.toString("hex"));'
# In .env.local, escape dollar signs to avoid env expansion:
ACCESS_PASSWORD_HASH=scrypt\$...\$...
# This is a random secret generated by the command:
# openssl rand -base64 32
ACCESS_COOKIE_SECRET=some-secret-string
